rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow unauthenticated access during admin setup
    match /users/{userId} {
      allow read, write: if request.auth == null || request.auth.uid == userId || isAdmin(request.auth.uid);
    }

    // Allow authenticated users to read/write to most collections if they are admin
    match /events/{eventId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /userEvents/{eventId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /vendors/{vendorId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /tasks/{taskId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /tickets/{ticketId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /guests/{guestId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /media/{mediaId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /sections/{sectionId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /budgets/{budgetId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }
  }

  function isAdmin(uid) {
    return get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin';
  }
}
